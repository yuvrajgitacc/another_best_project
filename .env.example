# ============================================
# SEVASETU - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- App ---
APP_NAME=SevaSetu
APP_ENV=development
SECRET_KEY=change-me-to-a-random-string-in-production
DEBUG=true

# --- Google OAuth ---
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Gemini AI (for OCR) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# --- Firebase Cloud Messaging ---
# FCM push notifications — get from Firebase Console → Project Settings → Cloud Messaging tab → Server Key
FCM_SERVER_KEY=your-fcm-server-key

# --- Database ---
DATABASE_URL=sqlite:///./smartalloc.db

# --- Turso (Cloud SQLite — for production) ---
# Get from: https://turso.tech → Create DB → Get URL & Token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- CORS ---
FRONTEND_ADMIN_URL=http://localhost:5173
FRONTEND_VOLUNTEER_URL=http://localhost:5174
 # Extra origins (comma-separated). Useful for Render + Capacitor WebView:
 # Example:
 # CORS_ORIGINS=https://your-backend.onrender.com,https://your-landing.onrender.com,capacitor://localhost
 CORS_ORIGINS=

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# --- OpenWeatherMap (for weather alerts) ---
# Get from: https://openweathermap.org/api
OWM_API_KEY=your-owm-api-key

# --- Frontend (Vite reads VITE_ prefixed vars) ---
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_OWM_API_KEY=your-owm-api-key
 # Backend base URL for the frontends (IMPORTANT for APK builds)
 # - When backend serves the web app (same-origin), you can leave this empty.
 # - For Capacitor / APK you MUST set this to your Render backend URL, e.g.:
 #   VITE_API_BASE_URL=https://your-service.onrender.com
 VITE_API_BASE_URL=
 # Optional request timeout (ms) for the volunteer app
 VITE_API_TIMEOUT_MS=20000
